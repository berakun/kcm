PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_database_password_here
DB_NAME=kcm_database

# JWT Settings
JWT_SECRET=change_this_to_a_random_secret_key
JWT_EXPIRES_IN=24h

# GPS Office Location
OFFICE_LAT=0.000000
OFFICE_LNG=0.000000
OFFICE_RADIUS=20

# Security Settings
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# CORS Origin
CORS_ORIGIN=http://localhost:5173

# Default Seed Accounts (username / password)
SEED_SUPER_ADMIN_USERNAME=your_admin_username
SEED_SUPER_ADMIN_PASSWORD=your_secure_password

SEED_ADMIN_USERNAME=your_admin_username
SEED_ADMIN_PASSWORD=your_secure_password

SEED_STAFF_USERNAME=your_staff_username
SEED_STAFF_PASSWORD=your_secure_password
